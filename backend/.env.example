# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to backend/ or absolute)
DB_PATH=./epl_stat.db

# ── Data directories ──────────────────────────────────────────────────────────
# Path to the FPL players CSV file (auto-downloaded from Kaggle on first start)
FPL_DATASET_PATH=../fpl_dataset/players.csv

# ── FPL API ───────────────────────────────────────────────────────────────────
FPL_API_BASE=https://fantasy.premierleague.com/api

# ── ML models ─────────────────────────────────────────────────────────────────
MODEL_DIR=./ml/saved_models
RAW_DATA_DIR=./data/raw

# ── Kaggle credentials (alternative to ~/.kaggle/kaggle.json) ─────────────────
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key
